{
  "family": "projectflow-frontend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::<AWS_ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<AWS_ACCOUNT_ID>:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "frontend",
      "image": "<AWS_ACCOUNT_ID>.dkr.ecr.<AWS_REGION>.amazonaws.com/<ECR_FRONTEND_REPO>:latest",
      "portMappings": [{ "containerPort": 3001, "protocol": "tcp" }],
      "essential": true,
      "environment": [
        { "name": "NEXT_PUBLIC_SUPABASE_URL", "value": "<SUPABASE_URL>" },
        { "name": "NEXT_PUBLIC_SUPABASE_ANON_KEY", "value": "<SUPABASE_ANON_KEY>" },
        { "name": "NEXT_PUBLIC_API_URL", "value": "<API_URL>" }
      ]
    }
  ]
}
